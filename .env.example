APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Base de datos
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Sesiones y Cache
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
CACHE_STORE=file

# Servicios (Opcionales, dejar vacíos en ejemplo)
MAIL_MAILER=log
REDIS_CLIENT=phpredis

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Administrador general inicial (solo para seeders, deploy inicial).
# Este usuario puede crear y gestionar a los administradores normales.
# Definir solo en producción la primera vez; luego crear admins desde la app.
ADMIN_NAME=Administrador general
ADMIN_EMAIL=
ADMIN_PASSWORD=

VITE_APP_NAME="${APP_NAME}"